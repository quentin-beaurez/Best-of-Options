    "def simulate_WT (N, t, rho) :\n",
    "    \"\"\"\n",
    "    Génère le vecteur gaussien (W_1(T), W_2(T), W_3(T)), de matrice de corrélation Gamma. \n",
    "    \"\"\"\n",
    "    G = normal_standard(3, N)\n",
    "\n",
    "    Gamma = [[1, rho, rho],\n",
    "             [rho, 1, rho],\n",
    "             [rho, rho, 1]]\n",
    "    \n",
    "    A = np.linalg.cholesky(Gamma)\n",
    "\n",
    "    WT = np.sqrt(T) * A @ G\n",
    "\n",
    "    return WT\n",
    "    \n",
    "    "
   ]
