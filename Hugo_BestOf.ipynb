    "def normal_standard(d, N) : \n",
    "    \"\"\"\n",
    "    Génère une matrice (d, N) de variables normales standard\n",
    "    \"\"\"\n",
    "\n",
    "    U = npr.random((d,N))\n",
    "    V = npr.random((d,N))\n",
    "\n",
    "    X = np.sqrt(-2 * np.log(U))*np.cos(2*np.pi*V)\n",
    "\n",
    "    return X "
